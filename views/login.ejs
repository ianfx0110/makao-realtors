<%- include('partials/head') %>

<div class="auth-wrapper">
    <div class="auth-card glass-panel">
        <div class="auth-header">
            <a href="/">
                <img src="/images/logo.svg" alt="Makao Logo" class="auth-logo" />
            </a>
            <h2>Welcome Back</h2>
            <p>Enter your phone number and password to sign in</p>
        </div>
        
        <% if (error) { %>
            <div class="alert alert-danger" style="margin-bottom: 20px; font-size: 13px; padding: 10px 14px;">
                <span><i class="fas fa-exclamation-circle" style="margin-right: 6px;"></i><%= error %></span>
            </div>
        <% } %>
        
        <form action="/login" method="POST" class="auth-form">
            <div class="form-group">
                <label for="phone_number" class="form-label">Phone Number</label>
                <div style="position: relative; display: flex; align-items: center;">
                    <i class="fas fa-phone" style="position: absolute; left: 16px; color: var(--color-text-muted);"></i>
                    <input type="text" id="phone_number" name="phone_number" class="form-control" placeholder="e.g. 0712345678" style="padding-left: 45px;" required />
                </div>
            </div>
            
            <div class="form-group">
                <label for="password" class="form-label">Password</label>
                <div class="input-password-container">
                    <i class="fas fa-lock" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--color-text-muted);"></i>
                    <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password" style="padding-left: 45px; padding-right: 45px;" required />
                    <button type="button" class="toggle-password" data-target="password">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px; padding: 12px 0;">
                Sign In <i class="fas fa-sign-in-alt"></i>
            </button>
        </form>
        
        <div class="auth-footer">
            <p>Don't have an account? <a href="/signup" style="font-weight: 700;">Sign Up Here</a></p>
            <p style="margin-top: 15px;"><a href="/" style="color: var(--color-text-muted);"><i class="fas fa-arrow-left"></i> Back to Homepage</a></p>
        </div>
    </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
