            { href: '/admin/users', label: 'Manage Users', icon: 'fa-users-cog' },
            { href: '/admin/listings', label: 'Properties Audit', icon: 'fa-home' },
            { href: '/admin/broadcast', label: 'Broadcasts', icon: 'fa-bullhorn' },
