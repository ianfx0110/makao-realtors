            { href: '/admin/users', label: 'Users', icon: 'fa-users-cog' },
            { href: '/admin/messages', label: 'Chats', icon: 'fa-comments' },
            { href: '/settings/profile', label: 'Settings', icon: 'fa-cog' }
        ];
    } else if (user.role === 'staff') {
        navLinks = [
