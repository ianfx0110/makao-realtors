<!DOCTYPE html>
<html lang="en" data-theme="<%= theme %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Makao Realtors - Premium Kenyan Housing Broker</title>
    
    <!-- Vector Browser Tab Icon -->
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    
    <!-- FontAwesome Vector Icon Library for Dashboards -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Premium Stylesheets -->
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Sync theme variable settings locally -->
    <script>
        const localTheme = localStorage.getItem('makao-theme') || 'light';
        document.documentElement.setAttribute('data-theme', localTheme);
    </script>
</head>
