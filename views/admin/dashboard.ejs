<%- include('../partials/head') %>
<%- include('../partials/header') %>

<div class="section-header">
    <div>
        <h2>Admin Control Center</h2>
        <p>Monitor platform statistics, manage registered users, and audit brokers</p>
    </div>
    <div style="display: flex; gap: 12px;">
        <a href="/admin/users" class="btn btn-primary btn-sm">
            <i class="fas fa-user-plus"></i> Add Support User
        </a>
        <a href="/admin/broadcast" class="btn btn-secondary btn-sm">
            <i class="fas fa-bullhorn"></i> New Broadcast
        </a>
    </div>
</div>

<!-- 1. Platform Statistics Dashboard -->
<div class="dashboard-grid">
    <div class="stat-card glass-panel">
        <div class="stat-info">
            <h3>Registered Members</h3>
            <div class="stat-value"><%= stats.users %></div>
        </div>
        <div class="stat-icon"><i class="fas fa-users"></i></div>
    </div>
    
    <div class="stat-card glass-panel">
        <div class="stat-info">
            <h3>Total Property Listings</h3>
            <div class="stat-value"><%= stats.listings %></div>
        </div>
        <div class="stat-icon"><i class="fas fa-building"></i></div>
    </div>
    
    <div class="stat-card glass-panel" style="border-left: 5px solid var(--color-success);">
        <div class="stat-info">
            <h3>Platform Balance (KES)</h3>
            <div class="stat-value" style="color: var(--color-success);">
                KES <%= parseFloat(stats.revenue).toLocaleString() %>
            </div>
        </div>
        <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--color-success);">
            <i class="fas fa-wallet"></i>
        </div>
    </div>
</div>

<!-- 2. Accounts Ledger & Management -->
<div class="glass-panel" style="padding: 30px; margin-bottom: 40px;">
    <h3 style="margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">
        <i class="fas fa-users-cog" style="margin-right: 8px; color: var(--color-primary);"></i>Platform User Accounts
    </h3>
    
    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Phone Number</th>
                    <th>Role</th>
                    <th>Balance</th>
                    <th>Account Status</th>
                    <th style="text-align: right;">Action Toggle</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(member => { %>
                    <tr>
                        <td><%= member.id %></td>
                        <td><strong><%= member.full_name %></strong></td>
                        <td><%= member.phone_number %></td>
                        <td>
                            <span class="badge badge-info" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">
                                <%= member.role %>
                            </span>
                        </td>
                        <td>KES <%= parseFloat(member.balance).toLocaleString() %></td>
                        <td>
                            <span class="badge <%= member.status === 'suspended' ? 'badge-danger' : 'badge-success' %>">
                                <%= member.status %>
                            </span>
                        </td>
                        <td style="text-align: right;">
                            <% if (member.id === user.id) { %>
                                <span style="font-size: 11px; color: var(--color-text-muted);">Current Admin</span>
                            <% } else { %>
                                <form action="/admin/users/suspend" method="POST" style="display: inline;">
                                    <input type="hidden" name="userId" value="<%= member.id %>" />
                                    <% if (member.status === 'suspended') { %>
                                        <input type="hidden" name="status" value="active" />
                                        <button type="submit" class="btn btn-success btn-sm" style="padding: 4px 10px;">
                                            <i class="fas fa-check-circle"></i> Activate
                                        </button>
                                    <% } else { %>
                                        <input type="hidden" name="status" value="suspended" />
                                        <button type="submit" class="btn btn-danger btn-sm" style="padding: 4px 10px;">
                                            <i class="fas fa-ban"></i> Suspend
                                        </button>
                                    <% } %>
                                </form>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
