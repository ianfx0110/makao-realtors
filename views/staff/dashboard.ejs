<%- include('../partials/head') %>
<%- include('../partials/header') %>

<div class="section-header">
    <div>
        <h2>Staff Support Dashboard</h2>
        <p>Assist users, verify listing payments, and connect buyers and renters with landlords and sellers</p>
    </div>
</div>

<!-- 1. Moderation Analytics Metrics Row -->
<div class="dashboard-grid">
    <div class="stat-card glass-panel" style="border-left: 5px solid var(--color-warning);">
        <div class="stat-info">
            <h3>Payments Awaiting Approval</h3>
            <div class="stat-value" style="color: var(--color-warning);"><%= stats.pending_payments %></div>
        </div>
        <div class="stat-icon" style="background: rgba(245, 158, 11, 0.1); color: var(--color-warning);">
            <i class="fas fa-file-invoice-dollar"></i>
        </div>
    </div>
    
    <div class="stat-card glass-panel" style="border-left: 5px solid var(--color-success);">
        <div class="stat-info">
            <h3>Active Connected Matches</h3>
            <div class="stat-value" style="color: var(--color-success);"><%= stats.active_connections %></div>
        </div>
        <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--color-success);">
            <i class="fas fa-link"></i>
        </div>
    </div>
</div>

<!-- 2. Recent Listings Review Grid -->
<div class="glass-panel" style="padding: 30px;">
    <h3 style="margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">
        <i class="fas fa-home" style="margin-right: 8px; color: var(--color-primary);"></i>Recently Submitted Properties
    </h3>
    
    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Property Title</th>
                    <th>Price</th>
                    <th>Type</th>
                    <th>Landlord/Seller</th>
                    <th>Availability Status</th>
                </tr>
            </thead>
            <tbody>
                <% listings.forEach(property => { %>
                    <tr>
                        <td><%= property.id %></td>
                        <td><strong><%= property.title %></strong></td>
                        <td>KES <%= parseFloat(property.price).toLocaleString() %></td>
                        <td>
                            <span class="badge badge-info" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">
                                <%= property.property_type %>
                            </span>
                        </td>
                        <td><%= property.owner_name %></td>
                        <td>
                            <span class="badge <%= property.availability === 'available' ? 'badge-success' : 'badge-danger' %>">
                                <%= property.availability %>
                            </span>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
