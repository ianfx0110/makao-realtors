<%- include('../partials/head') %>
<%- include('../partials/header') %>

<div class="section-header">
    <div>
        <h2>M-Pesa Payments Verification</h2>
        <p>Audit and approve pending KES 100 listing fees and 10% connection broker payments</p>
    </div>
</div>

<div class="glass-panel" style="padding: 30px;">
    <h3 style="margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">
        <i class="fas fa-file-invoice-dollar" style="margin-right: 8px; color: var(--color-primary);"></i>Pending Payments Queue
    </h3>
    
    <% if (payments.length === 0) { %>
        <div style="text-align: center; padding: 60px; color: var(--color-text-muted);">
            <i class="fas fa-check-double fa-3x" style="margin-bottom: 16px; color: var(--color-success);"></i>
            <h3>All Payments Caught Up!</h3>
            <p style="color: var(--color-text-secondary); margin-top: 8px;">No pending M-Pesa receipts are currently awaiting verification.</p>
        </div>
    <% } else { %>
        <div class="table-wrapper">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Receipt Code</th>
                        <th>Payer Name</th>
                        <th>Role</th>
                        <th>Payment For</th>
                        <th>Amount (KES)</th>
                        <th>M-Pesa Number</th>
                        <th>Checkout Date</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% payments.forEach(payment => { %>
                        <tr>
                            <td><code><%= payment.mpesa_receipt || 'STK PENDING' %></code></td>
                            <td><strong><%= payment.payer_name %></strong></td>
                            <td>
                                <span class="badge badge-info" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">
                                    <%= payment.payer_role %>
                                </span>
                            </td>
                            <td>
                                <div style="font-weight: 600;">
                                    <%= payment.payment_type === 'listing_fee' ? 'KES 100 Listing fee' : '10% Connection Fee' %>
                                </div>
                                <div style="font-size: 11px; color: var(--color-text-secondary);">
                                    <%= payment.property_title || 'General Account' %>
                                </div>
                            </td>
                            <td>
                                <strong style="color: var(--color-primary);">
                                    KES <%= parseFloat(payment.amount).toLocaleString() %>
                                </strong>
                            </td>
                            <td><%= payment.phone_number %></td>
                            <td><%= new Date(payment.created_at).toLocaleString() %></td>
                            <td style="text-align: right; min-width: 180px;">
                                <!-- Approve payment form -->
                                <form action="/staff/payments/approve" method="POST" style="display: inline;">
                                    <input type="hidden" name="payment_id" value="<%= payment.id %>" />
                                    <button type="submit" class="btn btn-success btn-sm" style="padding: 6px 12px; margin-right: 4px;">
                                        <i class="fas fa-check"></i> Approve
                                    </button>
                                </form>
                                
                                <!-- Reject payment form -->
                                <form action="/staff/payments/reject" method="POST" style="display: inline;">
                                    <input type="hidden" name="payment_id" value="<%= payment.id %>" />
                                    <button type="submit" class="btn btn-danger btn-sm" style="padding: 6px 12px;">
                                        <i class="fas fa-times"></i> Reject
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
